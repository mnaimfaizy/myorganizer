{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "module": "commonjs",
    "types": ["node", "express", "passport"],
    "composite": false,
    "lib": ["es2021", "dom"]
  },
  "include": [
    "src/**/*.ts",
    "src/swagger.js",
    "src/swagger/swagger.json",
    "src/swagger/swagger.yaml",
    "../../libs/prisma-schema/prisma/index.ts",
    "src/templates/**/*.html",
    "src/prisma/**/*.prisma"
  ],
  "exclude": ["jest.config.ts", "src/**/*.spec.ts", "src/**/*.test.ts"]
}
