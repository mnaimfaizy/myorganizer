# Keep direct dependencies pinned to the exact versions that were reviewed.
save-exact=true

# Keep npm installs lockfile-backed if a developer intentionally uses npm locally.
package-lock=true

# Surface advisories during local npm operations.
audit=true

# Delay new package releases for 7 days before npm can select them.
min-release-age=7

# Prefer a deduped tree when npm can do so safely.
prefer-dedupe=true

# Do not disable scripts globally. Use npm ci --ignore-scripts only for disposable review flows.
ignore-scripts=false