{
  "$schema": "https://design-tokens.github.io/community-group/format/schema.json",
  "$description": "MyOrganizer design tokens. Single source of truth for color, spacing, radius, typography, and shadow. See libs/design-tokens/README.md.",
  "color": {
    "$description": "Brand and semantic colors. Use these instead of hard-coded hex values.",
    "primary": {
      "$value": "#0F172A",
      "$type": "color",
      "$description": "Deep slate navy. Branding, primary text, grounding elements."
    },
    "secondary": {
      "$value": "#7C3AED",
      "$type": "color",
      "$description": "Electric purple. Cryptographic / secure-action CTAs."
    },
    "tertiary": {
      "$value": "#0F766E",
      "$type": "color",
      "$description": "Trust teal. Sync and persistent privacy indicators."
    },
    "cyan": {
      "$value": "#06B6D4",
      "$type": "color",
      "$description": "Action cyan. Active nodes and successful connections."
    },
    "destructive": {
      "$value": "#EF4444",
      "$type": "color",
      "$description": "Irreversible actions only (delete, purge)."
    },
    "surface": {
      "$value": "#F8FAFC",
      "$type": "color",
      "$description": "Page background (lowest tonal tier)."
    },
    "surface-container": {
      "$value": "#ECEEF0",
      "$type": "color",
      "$description": "Footer, pill, neutral chip backgrounds."
    },
    "card": {
      "$value": "#FFFFFF",
      "$type": "color",
      "$description": "Card / container surface."
    },
    "border": {
      "$value": "#E2E8F0",
      "$type": "color",
      "$description": "Hairline borders for cards, inputs."
    },
    "muted": {
      "$value": "#64748B",
      "$type": "color",
      "$description": "Secondary text, metadata."
    },
    "on-primary": {
      "$value": "#FFFFFF",
      "$type": "color"
    },
    "on-secondary": {
      "$value": "#FFFFFF",
      "$type": "color"
    }
  },
  "font": {
    "$description": "Font family stacks.",
    "display": {
      "$value": "'Plus Jakarta Sans', 'Inter', ui-sans-serif, system-ui, -apple-system, 'Segoe UI', sans-serif",
      "$type": "fontFamily",
      "$description": "Headlines and display titles."
    },
    "body": {
      "$value": "'Inter', ui-sans-serif, system-ui, -apple-system, 'Segoe UI', sans-serif",
      "$type": "fontFamily",
      "$description": "Body copy and UI labels."
    }
  },
  "radius": {
    "$description": "Border-radius scale.",
    "sm": { "$value": "0.25rem", "$type": "dimension" },
    "md": { "$value": "0.5rem", "$type": "dimension" },
    "lg": { "$value": "0.75rem", "$type": "dimension" },
    "xl": { "$value": "1rem", "$type": "dimension" },
    "2xl": { "$value": "1.5rem", "$type": "dimension" },
    "full": { "$value": "9999px", "$type": "dimension" }
  },
  "space": {
    "$description": "Spacing scale on a 4px baseline grid.",
    "xs": { "$value": "4px", "$type": "dimension" },
    "sm": { "$value": "8px", "$type": "dimension" },
    "md": { "$value": "16px", "$type": "dimension" },
    "lg": { "$value": "24px", "$type": "dimension" },
    "xl": { "$value": "32px", "$type": "dimension" },
    "gutter": { "$value": "16px", "$type": "dimension" },
    "margin-mobile": { "$value": "16px", "$type": "dimension" },
    "margin-desktop": { "$value": "24px", "$type": "dimension" }
  },
  "shadow": {
    "$description": "Elevation system. Prefer tonal layers over heavy shadow.",
    "card": {
      "$value": "0px 1px 3px rgba(15, 23, 42, 0.05)",
      "$type": "shadow",
      "$description": "Ambient card shadow per Secure Modernism spec."
    },
    "popover": {
      "$value": "0 12px 24px rgba(15, 23, 42, 0.08)",
      "$type": "shadow"
    }
  }
}
