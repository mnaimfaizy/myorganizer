{
  "name": "design-tokens",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/design-tokens/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build-tokens": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/src/generated"],
      "inputs": [
        "{projectRoot}/src/tokens.json",
        "{projectRoot}/style-dictionary.config.cjs",
        "{projectRoot}/scripts/build-tokens.cjs"
      ],
      "options": {
        "cwd": "libs/design-tokens",
        "command": "node scripts/build-tokens.cjs"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["libs/design-tokens/src/**/*.{ts,tsx,js}"]
      }
    }
  }
}
